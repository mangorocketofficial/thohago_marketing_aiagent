{
  "name": "@repo/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && node ./electron/run-dev-electron.mjs",
    "build": "vite build",
    "start": "electron ./electron/main.mjs",
    "type-check": "tsc --noEmit",
    "lint": "echo \"No lint rules for @repo/desktop yet\""
  },
  "dependencies": {
    "@repo/analytics": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/media-engine": "workspace:*",
    "@repo/types": "workspace:*",
    "@supabase/supabase-js": "^2.57.4",
    "cheerio": "^1.1.0",
    "chokidar": "^3.6.0",
    "exceljs": "^4.4.0",
    "i18next": "^25.6.0",
    "mammoth": "^1.11.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.3.5",
    "react-icons": "^5.6.0",
    "react-markdown": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "typescript": "^5.8.2",
    "vite": "^5.4.19",
    "wait-on": "^8.0.5"
  }
}
