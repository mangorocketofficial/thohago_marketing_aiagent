{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["API_PORT", "ORCHESTRATOR_API_BASE"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "type-check": {
      "dependsOn": ["^build"]
    }
  }
}
