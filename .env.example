# Supabase
# Local CLI workflow:
# 1) pnpm supabase:start
# 2) pnpm supabase:status:env
# 3) Map API_URL -> NEXT_PUBLIC_SUPABASE_URL
#    Map ANON_KEY -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#    Map SERVICE_ROLE_KEY -> SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# API (apps/api)
API_PORT=3001
API_SECRET=
ORCHESTRATOR_API_BASE=http://127.0.0.1:3001

# Subscription entitlement foundation (Phase 2-3)
SUBSCRIPTION_BYPASS=false
SUBSCRIPTION_DEFAULT_STATUS=active
SUBSCRIPTION_TRIAL_DAYS=14
# Optional desktop paywall checkout URL placeholder.
BILLING_CHECKOUT_URL=

# Anthropic (single provider for Phase 1-5)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5
ANTHROPIC_PROMPT_CACHING_ENABLED=true

# OpenAI
OPENAI_API_KEY=
OPENAI_PROFILE_MODEL=gpt-4o-mini
# Optional: force onboarding to use a fixed local review markdown file.
# Example: docs/브랜드리뷰_2026-03-01-05.md
ONBOARDING_PINNED_REVIEW_PATH=

# RAG / Embedding (Phase 2-1)
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=1536
RAG_ALLOWED_EMBEDDING_DIMENSIONS=512,768,1536
RAG_DEFAULT_TOP_K=5
RAG_DEFAULT_MIN_SIMILARITY=0.65
RAG_TIER1_TOKEN_BUDGET=2000
RAG_TIER2_TOKEN_BUDGET=4000
RAG_CONTEXT_TOTAL_BUDGET=6000
RAG_TIER2_TOTAL_BUDGET=4000
RAG_TIER2_BRAND_PROFILE_BUDGET=800
RAG_TIER2_CONTENT_BUDGET=1500
RAG_TIER2_LOCAL_DOC_BUDGET=1200
RAG_TIER2_CHAT_PATTERN_BUDGET=500
RAG_FORBIDDEN_CHECK_ENABLED=true
RAG_FORBIDDEN_MAX_RETRIES=1

# Conversation memory / cache (Phase 6-1)
WORKING_MEMORY_MAX_TURNS=12
WORKING_MEMORY_TOKEN_BUDGET=900
SESSION_SUMMARY_TOKEN_BUDGET=250
SESSION_SUMMARY_UPDATE_EVERY_TURNS=4
PREFERENCE_MEMORY_MAX_ITEMS=8
LLM_RESPONSE_CACHE_ENABLED=true
LLM_RESPONSE_CACHE_TTL_SECONDS=300

# Telegram
TELEGRAM_BOT_TOKEN=

# Optional: Naver Search API (used by Naver blog crawler hybrid collection)
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# Development seed
SEED_ORG_ID=a1b2c3d4-0000-0000-0000-000000000001
SEED_USER_ID=a1b2c3d4-0000-0000-0000-000000000002

# Optional RLS verification
RLS_TEST_USER_TOKEN=
RLS_OTHER_ORG_ID=

# Desktop renderer dev auth bootstrap (Phase 1-5b)
# Reuse RLS_TEST_USER_TOKEN value or provide another valid authenticated JWT.
DESKTOP_SUPABASE_ACCESS_TOKEN=
# System-browser OAuth callback port for desktop Google sign-in (Phase 1-6a).
DESKTOP_OAUTH_CALLBACK_PORT=48721
DESKTOP_OAUTH_CALLBACK_HOST=127.0.0.1
DESKTOP_OAUTH_TIMEOUT_MS=90000

# Optional: secure relay endpoint for desktop pipeline trigger writes
# Do not put service-role keys in desktop runtime.
PIPELINE_TRIGGER_ENDPOINT=http://localhost:3001/trigger
# Should match API_SECRET for local relay auth.
PIPELINE_TRIGGER_TOKEN=

# Optional: Instagram Graph Business Discovery crawler (desktop onboarding)
# Use a Facebook Graph user/page token with instagram_basic + pages_show_list + pages_read_engagement (+ business_management when needed).
Graph_META_ACCESS_TOKEN=
# Numeric IG user id for the business account that runs business_discovery.
# Example: 17841480545264675
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Optional aliases (same meaning as above)
INSTAGRAM_IG_USER_ID=
# Optional Facebook page id to auto-resolve linked instagram_business_account
FACEBOOK_PAGE_ID=
# Optional Graph API version override (default: v23.0)
INSTAGRAM_GRAPH_VERSION=v23.0
